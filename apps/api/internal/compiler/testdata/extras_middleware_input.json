[
  {
    "id": 300,
    "fleet_id": "homelab",
    "name": "guarded",
    "domain": "guarded.example.com",
    "upstream_url": "http://api:8080",
    "entry_points": ["web"],
    "middlewares": [
      {
        "name": "rl",
        "type": "rateLimit",
        "config": { "average": 100, "burst": 200 }
      },
      {
        "name": "lan",
        "type": "ipAllowList",
        "config": { "sourceRange": ["10.0.0.0/8", "192.168.0.0/16"] }
      },
      {
        "name": "back",
        "type": "retry",
        "config": { "attempts": 3, "initialInterval": "100ms" }
      },
      {
        "name": "gz",
        "type": "compress",
        "config": {}
      },
      {
        "name": "cb",
        "type": "circuitBreaker",
        "config": { "expression": "NetworkErrorRatio() > 0.50" }
      },
      {
        "name": "all",
        "type": "chain",
        "config": { "middlewares": ["rl", "lan", "back"] }
      }
    ],
    "enabled": true,
    "created_at": "2026-01-01T00:00:00Z",
    "updated_at": "2026-01-01T00:00:00Z"
  }
