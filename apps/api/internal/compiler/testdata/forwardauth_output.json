{
  "http": {
    "middlewares": {
      "private-api-0-oidc": {
        "forwardAuth": {
          "address": "http://oauth2-proxy:4180/oauth2/auth",
          "trustForwardHeader": true,
          "authResponseHeaders": [
            "X-Auth-Request-User",
            "X-Auth-Request-Email"
          ]
        }
      }
    },
    "routers": {
      "private-api": {
        "rule": "Host(`private.example.com`)",
        "service": "private-api",
        "entryPoints": ["websecure"],
        "middlewares": ["private-api-0-oidc"],
        "tls": {}
      }
    },
    "services": {
      "private-api": {
        "loadBalancer": {
          "servers": [{"url": "http://api:8080"}]
        }
      }
    }
  }
}
